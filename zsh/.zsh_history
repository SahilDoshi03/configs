: 1776834114:0;# Create the cache directory\
mkdir -p ~/.cache/awww\
\
# Create symlinks so HyDE finds the 'new' tools using 'old' names\
sudo ln -sf /usr/bin/awww /usr/bin/swww\
sudo ln -sf /usr/bin/awww-daemon /usr/bin/swww-daemon\
\
# Kill any stuck processes and reload\
pkill awww-daemon\
pkill swww-daemon\
swww-daemon --namespace "$WAYLAND_DISPLAY" &\
hyde-shell reload
